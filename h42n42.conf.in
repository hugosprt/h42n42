<ocsigen>
  <server>
    <port>8080</port>
    <charset>utf-8</charset>
    <commandpipe>/tmp/ocsigenserver_command</commandpipe>

    <extension findlib-package="ocsipersist-sqlite-config">
      <database file="/app/data/ocsidb"/>
    </extension>
    <extension findlib-package="ocsigenserver.ext.staticmod" />
    <extension findlib-package="eliom.server" />

    <host defaulthostname="localhost">
      <site path="/">
        <static dir="/app/static" />
        <eliommodule module="/app/_server/h42n42.cma" />
        <eliom />
      </site>
    </host>
  </server>
</ocsigen>